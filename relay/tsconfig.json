{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "types": ["@cloudflare/workers-types"],
    "lib": ["ES2022"]
  },
  "include": ["src/**/*.ts"],
  "comment": "dev-server.ts 為 node-only 進入點（用 esbuild 打包），不在 Worker 型別環境下型別檢查。",
  "exclude": ["src/dev-server.ts"]
}
