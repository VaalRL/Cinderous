{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cinder",
  "version": "0.0.0",
  "identifier": "app.nostrbuddy.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter @cinder/desktop dev",
    "beforeBuildCommand": "pnpm --filter @cinder/desktop build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Cinder",
        "width": 1024,
        "height": 720,
        "minWidth": 400,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
