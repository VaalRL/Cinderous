{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cinderous",
  "version": "0.0.1",
  "identifier": "app.cinder.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter @cinderous/desktop dev",
    "beforeBuildCommand": "pnpm --filter @cinderous/desktop build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Cinderous",
        "width": 1024,
        "height": 720,
        "minWidth": 400,
        "minHeight": 560,
        "dragDropEnabled": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
