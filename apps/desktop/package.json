{
  "name": "@cinder/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Cinder 桌面前端（Tauri + React/TS）",
  "license": "AGPL-3.0-only",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
