{
  "name": "@cinder/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Cinder CLI（ADR-0098）：無狀態的無頭收發工具（whoami/send/listen）。私鑰不落地、無本機明文歷史。",
  "license": "AGPL-3.0-only",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --format=esm --outfile=dist/cinder.js",
    "cinder": "pnpm build && node dist/cinder.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cinder/core": "workspace:*",
    "@cinder/engine": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
